    "response_parser_key": "openai_image_data",
    "capabilities": {
      "supports_reference_image": true,
      "max_reference_images": 16,
      "reference_field": "image[]",
      "supports_mask": true,
      "input_fidelity": "automatic_for_gpt_image_2",
