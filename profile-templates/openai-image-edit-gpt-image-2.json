{
  "id": "openai-image-edit-gpt-image-2",
  "label": "OpenAI Image edit - GPT Image 2",
  "description": "Official OpenAI Image API image-edit profile for GPT Image 2 reference-image workflows. Import creates a draft revision only.",
  "category": "openai_official",
  "compatible_copy_allowed": true,
  "compatible_warning": "OpenAI-compatible edit endpoints vary widely. Confirm multi-image, mask and output fields in the target channel before publishing.",
  "tags": ["openai", "image-api", "edit", "gpt-image-2"],
  "revision": {
    "source_kind": "openai_official",
    "source_url": "https://developers.openai.com/api/docs/guides/image-generation",
    "source_checked_at": "2026-06-22T00:00:00.000Z",
    "source_summary": "OpenAI Image API edit template for GPT Image 2. Uses multipart form-data, repeated image[] references and documented output customization fields.",
    "adapter_key": "openai_images_edit",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "gpt-image-2",
    "upstream_endpoint_path": "/v1/images/edits",
    "reference_transfer_mode": "multipart",
    "supports_reference_image": true,
    "max_reference_images": 8,
    "parameter_schema": [
      {
        "key": "size",
        "label": "分辨率",
        "type": "select",
        "required": false,
        "default": "1024x1024",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "1024 x 1024", "value": "1024x1024" },
          { "label": "1536 x 1024", "value": "1536x1024" },
          { "label": "1024 x 1536", "value": "1024x1536" }
        ],
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 20
        },
        "capability": "resolution",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "1024x1024", "1536x1024", "1024x1536"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "quality",
        "label": "质量",
        "type": "select",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Low", "value": "low" },
          { "label": "Medium", "value": "medium" },
          { "label": "High", "value": "high" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "quality",
          "order": 30
        },
        "capability": "quality",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "low", "medium", "high"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "output_format",
        "label": "输出格式",
        "type": "select",
        "required": false,
        "default": "png",
        "options": [
          { "label": "PNG", "value": "png" },
          { "label": "JPEG", "value": "jpeg" },
          { "label": "WebP", "value": "webp" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "format",
          "order": 40
        },
        "capability": "format",
        "send_policy": "when_present",
        "validation": {
          "enum": ["png", "jpeg", "webp"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "background",
        "label": "背景",
        "type": "select",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Opaque", "value": "opaque" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "background",
          "order": 50
        },
        "capability": "background",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "opaque"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      }
    ],
    "default_params": {
      "size": "1024x1024",
      "quality": "auto",
      "output_format": "png",
      "background": "auto"
    },
    "request_mapping": {
      "content_type": "multipart",
      "reference_field": {
        "target": "image[]",
        "mode": "repeat"
      },
      "fields": [
        { "source": "model", "target": "model" },
        { "source": "prompt", "target": "prompt" },
        { "source": "params.size", "target": "size", "omit_if_null": true },
        { "source": "params.quality", "target": "quality", "omit_if_null": true },
        {
          "source": "params.output_format",
          "target": "output_format",
          "omit_if_null": true
        },
        { "source": "params.background", "target": "background", "omit_if_null": true }
      ]
    },
    "response_parser_key": "openai_image_data",
    "capabilities": {
      "supports_reference_image": true,
      "max_reference_images": 8,
      "reference_field": "image[]",
      "supports_mask": true,
      "template_origin": "openai_official"
    },
    "validation_rules": {
      "version": 1,
      "notes": [
        "Mask upload UI is not part of this phase; this template enables reference-image edits only.",
        "GPT Image 2 processes image inputs at high fidelity automatically."
      ]
    },
    "change_summary": "Imported OpenAI official GPT Image 2 edit template."
  }
}
