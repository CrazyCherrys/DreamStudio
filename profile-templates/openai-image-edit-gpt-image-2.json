        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "moderation",
        "label": "内容审核",
        "type": "select",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Low", "value": "low" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "safety",
          "order": 60
