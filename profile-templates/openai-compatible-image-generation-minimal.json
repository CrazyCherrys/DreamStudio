{
  "id": "openai-compatible-image-generation-minimal",
  "label": "OpenAI-compatible image generation - minimal",
  "description": "Minimal OpenAI-compatible generation template for third-party channels. It intentionally avoids OpenAI-only full parameter assumptions.",
  "category": "openai_compatible",
  "compatible_copy_allowed": false,
  "compatible_warning": "Confirm every field against the target channel. This minimal template is a starting point, not proof of provider support.",
  "tags": ["openai-compatible", "new-api", "generation", "minimal"],
  "revision": {
    "source_kind": "third_party_docs",
    "source_url": "https://github.com/QuantumNous/new-api-docs/blob/main/docs/en/api/openai-image.md",
    "source_checked_at": "2026-06-25T00:00:00.000Z",
    "source_summary": "Generic OpenAI-compatible image generation template based on new-api OpenAI Image docs. It declares only model, prompt, n, size and response_format and intentionally excludes OpenAI-specific full parameter sets.",
    "adapter_key": "openai_images_generation",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "provider-image-model",
    "upstream_endpoint_path": "/v1/images/generations",
    "reference_transfer_mode": "none",
    "supports_reference_image": false,
    "max_reference_images": 0,
    "parameter_schema": [
      {
        "key": "n",
        "label": "张数",
        "type": "integer",
        "description": "一次请求生成的图片数量；具体上限必须以目标渠道文档为准。",
        "required": false,
        "default": 1,
        "min": 1,
        "max": 1,
        "ui": {
          "group": "quick",
          "slot": "count",
          "order": 10
        },
        "capability": "count",
        "send_policy": "when_present",
        "validation": {
          "min": 1,
          "max": 1,
          "custom_validator": "compatible_field_confirmed",
          "review_status": "confirmed"
        },
        "help_url": "https://github.com/QuantumNous/new-api-docs/blob/main/docs/en/api/openai-image.md"
      },
      {
        "key": "size",
        "label": "分辨率",
        "type": "select",
        "description": "通用 OpenAI-compatible 尺寸起点；发布前必须按目标渠道删改。",
        "required": false,
        "default": "1024x1024",
        "options": [
          { "label": "1024 x 1024", "value": "1024x1024" },
          { "label": "1024 x 1792", "value": "1024x1792" },
          { "label": "1792 x 1024", "value": "1792x1024" }
        ],
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 20
        },
        "capability": "resolution",
        "send_policy": "when_present",
        "validation": {
          "enum": ["1024x1024", "1024x1792", "1792x1024"],
          "custom_validator": "compatible_field_confirmed",
          "review_status": "confirmed"
        },
        "help_url": "https://github.com/QuantumNous/new-api-docs/blob/main/docs/en/api/openai-image.md"
      },
      {
        "key": "response_format",
        "label": "响应格式",
        "type": "select",
        "description": "返回 URL 或 b64_json；发布前确认目标渠道是否支持。",
        "required": false,
        "default": "url",
        "options": [
          { "label": "URL", "value": "url" },
          { "label": "Base64 JSON", "value": "b64_json" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "format",
          "order": 30
        },
        "capability": "response_format",
        "send_policy": "when_present",
        "validation": {
          "enum": ["url", "b64_json"],
          "custom_validator": "compatible_field_confirmed",
          "review_status": "confirmed"
        },
        "help_url": "https://github.com/QuantumNous/new-api-docs/blob/main/docs/en/api/openai-image.md"
      }
    ],
    "default_params": {
      "n": 1,
      "size": "1024x1024",
      "response_format": "url"
    },
    "request_mapping": {
      "content_type": "json",
      "fields": [
        { "source": "model", "target": "model" },
        { "source": "prompt", "target": "prompt" },
        { "source": "params.n", "target": "n", "omit_if_null": true },
        { "source": "params.size", "target": "size", "omit_if_null": true },
        {
          "source": "params.response_format",
          "target": "response_format",
          "omit_if_null": true
        }
      ]
    },
    "response_parser_key": "openai_image_data",
    "capabilities": {
      "supports_reference_image": false,
      "max_reference_images": 0,
      "template_origin": "openai_compatible",
      "requires_provider_field_review": true
    },
    "validation_rules": {
      "version": 1,
      "warnings": [
        "OpenAI-compatible does not imply OpenAI-full-compatible.",
        "Delete any parameter not confirmed by the target channel before publishing."
      ]
    },
    "change_summary": "Imported minimal OpenAI-compatible generation template; remove unconfirmed fields before publishing."
  }
}
