          "max": 4
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "size",
        "label": "分辨率",
        "type": "select",
        "description": "GPT Image 2 支持 auto 和满足约束的分辨率；模板列出常用安全值。",
        "required": false,
        "default": "1024x1024",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "1024 x 1024", "value": "1024x1024" },
          { "label": "1536 x 1024", "value": "1536x1024" },
          { "label": "1024 x 1536", "value": "1024x1536" },
          { "label": "2048 x 2048", "value": "2048x2048" },
          { "label": "2048 x 1152", "value": "2048x1152" },
          { "label": "3840 x 2160", "value": "3840x2160" },
          { "label": "2160 x 3840", "value": "2160x3840" }
        ],
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 20
        },
        "capability": "resolution",
        "send_policy": "when_present",
        "validation": {
          "enum": [
            "auto",
            "1024x1024",
            "1536x1024",
            "1024x1536",
            "2048x2048",
            "2048x1152",
            "3840x2160",
            "2160x3840"
          ]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "quality",
        "label": "质量",
        "type": "select",
        "description": "渲染质量。",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Low", "value": "low" },
          { "label": "Medium", "value": "medium" },
          { "label": "High", "value": "high" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "quality",
          "order": 30
        },
        "capability": "quality",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "low", "medium", "high"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "output_format",
        "label": "输出格式",
        "type": "select",
        "description": "图片输出格式。",
        "required": false,
        "default": "png",
        "options": [
          { "label": "PNG", "value": "png" },
          { "label": "JPEG", "value": "jpeg" },
          { "label": "WebP", "value": "webp" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "format",
          "order": 40
        },
        "capability": "format",
        "send_policy": "when_present",
        "validation": {
          "enum": ["png", "jpeg", "webp"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "output_compression",
        "label": "输出压缩",
        "type": "integer",
        "description": "JPEG/WebP 输出压缩级别，范围 0-100。",
        "required": false,
        "min": 0,
        "max": 100,
        "ui": {
          "group": "advanced",
          "slot": "format",
          "order": 50
        },
        "capability": "format",
        "send_policy": "when_present",
        "validation": {
          "min": 0,
          "max": 100,
          "custom_validator": "openai_output_compression_requires_jpeg_or_webp"
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "background",
        "label": "背景",
        "type": "select",
        "description": "GPT Image 2 当前不支持 transparent；模板只开放 auto 和 opaque。",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Opaque", "value": "opaque" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "background",
          "order": 60
        },
        "capability": "background",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "opaque"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "moderation",
        "label": "内容审核",
        "type": "select",
        "description": "控制图片生成审核严格程度。",
        "required": false,
        "default": "auto",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Low", "value": "low" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "safety",
          "order": 70
        },
        "capability": "safety",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "low"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "stream",
        "label": "流式输出",
        "type": "boolean",
        "description": "启用 OpenAI Image API streaming；当前 Studio 仅保存最终图片。",
        "required": false,
        "default": false,
        "ui": {
          "group": "hidden",
          "slot": "style",
          "order": 80
        },
        "capability": "streaming",
        "send_policy": "when_present",
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "partial_images",
        "label": "流式预览张数",
        "type": "integer",
        "description": "请求 OpenAI 返回的 partial image 数量，范围 0-3；大于 0 时必须启用 stream。",
        "required": false,
        "default": 0,
        "min": 0,
        "max": 3,
        "ui": {
          "group": "hidden",
          "slot": "count",
          "order": 90
        },
        "capability": "streaming",
        "send_policy": "when_present",
        "validation": {
          "min": 0,
          "max": 3,
          "custom_validator": "openai_partial_images_requires_stream"
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      }
    ],
    "default_params": {
      "n": 1,
      "size": "1024x1024",
      "quality": "auto",
      "output_format": "png",
      "background": "auto",
      "moderation": "auto",
      "stream": false,
      "partial_images": 0
    },
    "request_mapping": {
      "content_type": "json",
      "fields": [
        { "source": "model", "target": "model" },
        { "source": "prompt", "target": "prompt" },
        { "source": "params.n", "target": "n", "omit_if_null": true },
        { "source": "params.size", "target": "size", "omit_if_null": true },
        { "source": "params.quality", "target": "quality", "omit_if_null": true },
        {
          "source": "params.output_format",
          "target": "output_format",
          "omit_if_null": true
        },
        {
          "source": "params.output_compression",
          "target": "output_compression",
          "omit_if_null": true
        },
        { "source": "params.background", "target": "background", "omit_if_null": true },
        { "source": "params.moderation", "target": "moderation", "omit_if_null": true },
        { "source": "params.stream", "target": "stream", "omit_if_null": true },
        {
          "source": "params.partial_images",
          "target": "partial_images",
          "omit_if_null": true
        }
      ]
    },
    "response_parser_key": "openai_image_data",
    "capabilities": {
      "supports_reference_image": false,
      "max_reference_images": 0,
      "output_formats": ["png", "jpeg", "webp"],
      "supports_streaming": true,
      "transparent_background": false,
      "template_origin": "openai_official"
    },
    "validation_rules": {
      "version": 1,
      "notes": [
        "GPT Image 2 does not currently support transparent backgrounds.",
        "2K and larger output sizes should be treated as higher-cost profile choices.",
        "Studio v1 does not surface partial image previews; stream and partial_images remain hidden by default."
      ]
    },
    "change_summary": "Imported OpenAI official GPT Image 2 generation template."
  }
}
