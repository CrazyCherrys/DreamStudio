{
  "id": "openai-image-generation-gpt-image-2",
  "label": "OpenAI Image generation - GPT Image 2",
  "description": "Official OpenAI Image API text-to-image profile for GPT Image 2. Import creates a draft revision only.",
  "category": "openai_official",
  "compatible_copy_allowed": true,
  "compatible_warning": "OpenAI-compatible channels are not OpenAI-full-compatible. Delete every parameter that is not explicitly confirmed by the target channel before publishing.",
  "tags": ["openai", "image-api", "generation", "gpt-image-2"],
  "bootstrap": {
    "enabled": true,
    "profile_name": "OpenAI Image generation",
    "operation": "text_to_image",
    "sort_order": 0
  },
  "revision": {
    "source_kind": "openai_official",
    "source_url": "https://developers.openai.com/api/docs/guides/image-generation",
    "source_checked_at": "2026-06-25T00:00:00.000Z",
    "source_summary": "OpenAI Image API generation template for GPT Image 2. Exposes documented GPT Image 2 generation fields: n, size, quality, output format, output compression, background, moderation, stream and partial_images.",
    "adapter_key": "openai_images_generation",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "gpt-image-2",
    "upstream_endpoint_path": "/v1/images/generations",
    "reference_transfer_mode": "none",
    "supports_reference_image": false,
    "max_reference_images": 0,
    "parameter_schema": [
