{
  "id": "gemini-generate-content-image",
  "label": "Gemini generateContent image",
  "description": "Official Gemini image generation profile using generateContent with responseModalities and inlineData image output. Import creates a draft revision only.",
  "category": "gemini_official",
  "compatible_copy_allowed": false,
  "compatible_warning": "Gemini generateContent is not OpenAI-compatible. Enable this profile only when the configured new-api gateway supports the native Gemini path.",
  "tags": ["gemini", "generate-content", "image", "nano-banana"],
  "revision": {
    "source_kind": "gemini_official",
    "source_url": "https://ai.google.dev/gemini-api/docs/image-generation",
    "source_checked_at": "2026-06-25T00:00:00.000Z",
    "source_summary": "Gemini official generateContent image template for the current DreamStudio gateway-compatible Gemini image path.",
    "adapter_key": "gemini_generate_content",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "gemini-2.5-flash-image",
    "upstream_endpoint_path": "/v1beta/models/gemini-2.5-flash-image:generateContent",
    "reference_transfer_mode": "url",
    "supports_reference_image": true,
    "max_reference_images": 8,
    "parameter_schema": [
      {
        "key": "aspect_ratio",
        "label": "比例",
        "type": "select",
        "description": "Gemini image response aspect ratio.",
        "required": false,
        "default": "1:1",
        "options": [
          { "label": "1:1", "value": "1:1" },
          { "label": "2:3", "value": "2:3" },
          { "label": "3:2", "value": "3:2" },
          { "label": "3:4", "value": "3:4" },
          { "label": "4:3", "value": "4:3" },
          { "label": "9:16", "value": "9:16" },
          { "label": "16:9", "value": "16:9" }
        ],
        "ui": {
          "group": "quick",
          "slot": "aspect_ratio",
          "order": 10
        },
        "capability": "aspect_ratio",
        "send_policy": "when_present",
        "validation": {
          "enum": ["1:1", "2:3", "3:2", "3:4", "4:3", "9:16", "16:9"]
        },
        "help_url": "https://ai.google.dev/gemini-api/docs/image-generation"
      },
      {
        "key": "image_size",
        "label": "图片尺寸",
        "type": "select",
        "description": "Gemini image size tier.",
        "required": false,
        "default": "1K",
        "options": [
          { "label": "1K", "value": "1K" },
          { "label": "2K", "value": "2K" },
          { "label": "4K", "value": "4K" }
        ],
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 20
        },
        "capability": "image_size",
        "send_policy": "when_present",
        "validation": {
          "enum": ["1K", "2K", "4K"]
        },
        "help_url": "https://ai.google.dev/gemini-api/docs/image-generation"
      }
    ],
    "default_params": {
      "aspect_ratio": "1:1",
      "image_size": "1K"
    },
    "request_mapping": {
      "content_type": "json",
      "fields": [
        { "source": "prompt", "target": "contents[0].parts[0].text" },
        {
          "source": "params.aspect_ratio",
          "target": "generationConfig.imageConfig.aspectRatio",
          "omit_if_null": true
        },
        {
          "source": "params.image_size",
          "target": "generationConfig.imageConfig.imageSize",
          "omit_if_null": true
        }
      ],
      "constants": [{ "target": "generationConfig.responseModalities", "value": ["IMAGE"] }]
    },
    "response_parser_key": "gemini_inline_data",
    "capabilities": {
      "supports_reference_image": true,
      "max_reference_images": 8,
      "response_parser": "gemini_inline_data",
      "template_origin": "gemini_official",
      "requires_gateway_support": true
    },
    "validation_rules": {
      "version": 1,
      "warnings": [
        "Enable only when the configured new-api gateway supports /v1beta/models/{model}:generateContent.",
        "Gemini generateContent is not OpenAI-compatible and must use the gemini_generate_content adapter."
      ]
    },
    "change_summary": "Imported Gemini official generateContent image template."
  }
}
