{
  "id": "openai-responses-image-tool",
  "label": "OpenAI Responses image tool",
  "description": "Official OpenAI Responses API template for the image_generation built-in tool. Import creates a draft revision only.",
  "category": "openai_official",
  "compatible_copy_allowed": false,
  "compatible_warning": "Responses image tool compatibility must be confirmed per provider and is not assumed for OpenAI-compatible image endpoints.",
  "tags": ["openai", "responses", "image_generation"],
  "bootstrap": {
    "enabled": true,
    "profile_name": "OpenAI Responses image",
    "operation": "text_to_image",
    "sort_order": 0
  },
  "revision": {
    "source_kind": "openai_official",
    "source_url": "https://developers.openai.com/api/docs/guides/image-generation",
    "source_checked_at": "2026-06-25T00:00:00.000Z",
    "source_summary": "OpenAI Responses API image_generation tool template using the image_generation built-in tool.",
    "adapter_key": "openai_responses_image",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "gpt-5.5",
    "upstream_endpoint_path": "/v1/responses",
    "reference_transfer_mode": "url",
    "supports_reference_image": true,
    "max_reference_images": 8,
    "parameter_schema": [
      {
        "key": "size",
        "label": "分辨率",
        "type": "string",
        "description": "OpenAI Responses image_generation tool size. 支持 auto 或符合模型约束的 WIDTHxHEIGHT。",
        "required": false,
        "default": "auto",
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 5
        },
        "capability": "resolution",
        "send_policy": "when_present",
        "validation": {
          "regex": "^(auto|[1-9][0-9]{2,4}x[1-9][0-9]{2,4})$"
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "action",
        "label": "图片动作",
        "type": "select",
        "required": false,
        "default": "generate",
        "options": [
          { "label": "Auto", "value": "auto" },
          { "label": "Generate", "value": "generate" },
          { "label": "Edit", "value": "edit" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "style",
          "order": 10
        },
        "capability": "responses_image_action",
        "send_policy": "when_present",
        "validation": {
          "enum": ["auto", "generate", "edit"]
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "partial_images",
        "label": "流式预览张数",
        "type": "integer",
        "required": false,
        "default": 0,
        "min": 0,
        "max": 3,
        "ui": {
          "group": "advanced",
          "slot": "count",
          "order": 20
        },
        "capability": "streaming",
        "send_policy": "when_present",
        "validation": {
          "min": 0,
          "max": 3,
          "custom_validator": "openai_partial_images_requires_stream"
        },
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      },
      {
        "key": "stream",
        "label": "流式输出",
        "type": "boolean",
        "required": false,
        "default": false,
        "ui": {
          "group": "hidden",
          "slot": "style",
          "order": 30
        },
        "capability": "streaming",
        "send_policy": "when_present",
        "help_url": "https://developers.openai.com/api/docs/guides/image-generation"
      }
    ],
    "default_params": {
      "size": "auto",
      "action": "generate",
      "partial_images": 0,
      "stream": false
    },
    "request_mapping": {
      "content_type": "json",
      "fields": [
        { "source": "model", "target": "model" },
        { "source": "prompt", "target": "input", "transform": "promptToResponsesInput" },
        { "source": "params.size", "target": "tools[0].size", "omit_if_null": true },
        { "source": "params.action", "target": "tools[0].action", "omit_if_null": true },
        {
          "source": "params.partial_images",
          "target": "tools[0].partial_images",
          "omit_if_null": true
        },
        {
          "source": "params.stream",
          "target": "stream",
          "omit_if_null": true
        }
      ],
      "constants": [{ "target": "tools[0].type", "value": "image_generation" }]
    },
    "response_parser_key": "openai_responses_image_generation_call",
    "capabilities": {
      "supports_reference_image": true,
      "max_reference_images": 8,
      "supports_streaming": true,
      "runtime_supported": true,
      "template_origin": "openai_official"
    },
    "validation_rules": {
      "version": 1,
      "notes": [
        "Choose a mainline Responses model that supports the image_generation tool before publishing.",
        "Studio v1 stores final images only and does not display partial image previews."
      ]
    },
    "change_summary": "Imported OpenAI official Responses image tool template."
  }
}
