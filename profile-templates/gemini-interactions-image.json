{
  "id": "gemini-interactions-image",
  "label": "Gemini Interactions image",
  "description": "Gemini official Interactions image template for gemini-3-pro-image-preview and newer official image models. Import creates a draft revision only.",
  "category": "gemini_official",
  "compatible_copy_allowed": false,
  "compatible_warning": "Gemini Interactions is not OpenAI-compatible. Publish only after the configured new-api gateway has been verified against /v1beta/interactions.",
  "tags": ["gemini", "interactions", "image", "gemini-3"],
  "revision": {
    "source_kind": "gemini_official",
    "source_url": "https://ai.google.dev/gemini-api/docs/image-generation",
    "source_checked_at": "2026-06-25T00:00:00.000Z",
    "source_summary": "Gemini image generation guide snapshot for the Interactions API. Preferred official path for gemini-3-pro-image-preview and newer image models.",
    "adapter_key": "gemini_interactions_image",
    "adapter_version": "1",
    "transport_key": "new_api_bearer",
    "upstream_model_id": "gemini-3-pro-image-preview",
    "upstream_endpoint_path": "/v1beta/interactions",
    "reference_transfer_mode": "url",
    "supports_reference_image": true,
    "max_reference_images": 14,
    "parameter_schema": [
      {
        "key": "aspect_ratio",
        "label": "比例",
        "type": "select",
        "required": false,
        "default": "1:1",
        "options": [
          { "label": "1:1", "value": "1:1" },
          { "label": "2:3", "value": "2:3" },
          { "label": "3:2", "value": "3:2" },
          { "label": "3:4", "value": "3:4" },
          { "label": "4:3", "value": "4:3" },
          { "label": "9:16", "value": "9:16" },
          { "label": "16:9", "value": "16:9" }
        ],
        "ui": {
          "group": "quick",
          "slot": "aspect_ratio",
          "order": 10
        },
        "capability": "aspect_ratio",
        "send_policy": "when_present",
        "validation": {
          "enum": ["1:1", "2:3", "3:2", "3:4", "4:3", "9:16", "16:9"]
        },
        "help_url": "https://ai.google.dev/gemini-api/docs/image-generation"
      },
      {
        "key": "image_size",
        "label": "图片尺寸",
        "type": "select",
        "required": false,
        "default": "1K",
        "options": [
          { "label": "1K", "value": "1K" },
          { "label": "2K", "value": "2K" },
          { "label": "4K", "value": "4K" }
        ],
        "ui": {
          "group": "quick",
          "slot": "resolution",
          "order": 20
        },
        "capability": "image_size",
        "send_policy": "when_present",
        "validation": {
          "enum": ["1K", "2K", "4K"]
        },
        "help_url": "https://ai.google.dev/gemini-api/docs/image-generation"
      },
      {
        "key": "mime_type",
        "label": "输出 MIME",
        "type": "select",
        "required": false,
        "default": "image/png",
        "options": [
          { "label": "PNG", "value": "image/png" },
          { "label": "JPEG", "value": "image/jpeg" },
          { "label": "WebP", "value": "image/webp" }
        ],
        "ui": {
          "group": "advanced",
          "slot": "format",
          "order": 30
        },
        "capability": "format",
        "send_policy": "when_present",
        "validation": {
          "enum": ["image/png", "image/jpeg", "image/webp"]
        },
        "help_url": "https://ai.google.dev/gemini-api/docs/image-generation"
      }
    ],
    "default_params": {
      "aspect_ratio": "1:1",
      "image_size": "1K",
      "mime_type": "image/png"
    },
    "request_mapping": {
      "content_type": "json",
      "fields": [
        { "source": "model", "target": "model" },
        { "source": "prompt", "target": "input[0].text" },
        {
          "source": "params.mime_type",
          "target": "response_format.mime_type",
          "omit_if_null": true
        },
        {
          "source": "params.aspect_ratio",
          "target": "response_format.aspect_ratio",
          "omit_if_null": true
        },
        {
          "source": "params.image_size",
          "target": "response_format.image_size",
          "omit_if_null": true
        }
      ],
      "constants": [{ "target": "response_format.type", "value": "image" }]
    },
    "response_parser_key": "gemini_inline_data",
    "capabilities": {
      "supports_reference_image": true,
      "max_reference_images": 14,
      "runtime_supported": true,
      "template_origin": "gemini_official",
      "requires_gateway_support": true
    },
    "validation_rules": {
      "version": 1,
      "warnings": [
        "Verify the configured new-api gateway against /v1beta/interactions before activation.",
        "Gemini Interactions is not OpenAI-compatible and must use a dedicated adapter."
      ]
    },
    "change_summary": "Imported Gemini official Interactions image template for gemini-3-pro-image-preview and newer models."
  }
}
